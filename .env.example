# Copy to .env.local for local development (never commit .env.local)

# Supabase
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Anthropic / Claude
ANTHROPIC_API_KEY=sk-ant-...

# Zadarma
ZADARMA_API_KEY=<zadarma-api-key>
ZADARMA_API_SECRET=<zadarma-api-secret>

# Optional: custom system prompt for the SMS assistant
SYSTEM_PROMPT=Jesteś pomocnym asystentem AI. Odpowiadaj zwięźle, bo komunikujesz się przez SMS.
